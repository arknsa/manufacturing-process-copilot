              "name": "slack_text",
              "value": "=:white_check_mark: *Morning Risk Sweep* ({{ $now.toFormat('yyyy-LL-dd') }}) — No production orders scheduled today. Nothing to score.",
              "type": "string"
            },
            {
              "id": "e-scanned",
              "name": "orders_scanned",
              "value": "0",
              "type": "number"
            },
            {
              "id": "e-high",
              "name": "high_risk_count",
              "value": "0",
              "type": "number"
            },
            {
              "id": "e-failed",
              "name": "scoring_failed_count",
              "value": "0",
              "type": "number"
            },
            {
              "id": "e-audit",
