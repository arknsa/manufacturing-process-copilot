      "id": "2c1a0006-0000-0000-0000-000000000006",
      "name": "Enrich scored order",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1340, 220]
    },
    {
      "parameters": {
        "type": "simple",
        "sortFieldsUi": {
          "sortField": [
