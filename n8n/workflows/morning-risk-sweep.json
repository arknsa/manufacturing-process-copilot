              "value": "={{ ({ workflow: 'morning_risk_sweep', run_id: $execution.id, trigger: 'schedule', scanned_at: $now.toISO(), orders_scanned: 0, high_risk_count: 0, scoring_failed_count: 0, threshold: 0.7, note: 'no_orders_scheduled' }) }}",
              "type": "object"
            }
          ]
        },
        "options": {}
      },
      "id": "2c1a0010-0000-0000-0000-000000000010",
      "name": "Build empty digest",
