          ]
        },
        "options": {}
      },
      "id": "2c1a0007-0000-0000-0000-000000000007",
      "name": "Sort by risk desc",
      "type": "n8n-nodes-base.sort",
      "typeVersion": 1,
      "position": [1560, 220]
    },
    {
      "parameters": {
        "aggregate": "aggregateAllItemData",
        "destinationFieldName": "orders",
        "options": {}
      },
      "id": "2c1a0008-0000-0000-0000-000000000008",
      "name": "Roll up scored orders",
      "type": "n8n-nodes-base.aggregate",
      "typeVersion": 1,
      "position": [1780, 220]
    },
    {
      "parameters": {
        "jsCode": "// Build the morning risk digest from the single aggregated item.\n// Runs once over { orders: [...] }. Filtering + thresholding live here so a\n// zero-high-risk morning STILL produces an 'all clear' digest (a native Filter\n// node would emit zero items and silently skip the notification + audit tail).\nconst THRESHOLD = 0.70; // mirrors backend HIGH_RISK_THRESHOLD\n\n// Runs in 'Run Once for All Items' mode; Aggregate emits exactly one item.\nconst orders = $input.first().json.orders || [];\nconst scanned = orders.length;\n\nconst failed = orders.filter((o) => !o.scored_ok);\nconst highRisk = orders\n  .filter((o) => o.scored_ok && o.delay_probability >= THRESHOLD)\n  .sort((a, b) => b.delay_probability - a.delay_probability);\n\nconst now = new Date().toISOString();\n\nconst lines = highRisk\n  .map((o, i) => {\n    const pct = (o.delay_probability * 100).toFixed(0);\n    const pri = (o.priority || '').toUpperCase();\n    return `${i + 1}. *${o.order_number}* — ${pct}% delay risk | ${o.root_cause} | ${pri} | driver: ${o.top_factor}`;\n  })\n  .join('\\n');\n\nconst header =\n  highRisk.length > 0\n    ? `:rotating_light: *Morning Risk Sweep* — ${highRisk.length} high-risk of ${scanned} order(s) scheduled today (threshold \\u2265 ${(THRESHOLD * 100).toFixed(0)}%)`\n    : `:white_check_mark: *Morning Risk Sweep* — 0 high-risk of ${scanned} order(s) scheduled today. All clear.`;\n\nconst failedNote = failed.length\n  ? `\\n_\\u26a0 ${failed.length} order(s) could not be scored and were skipped._`\n  : '';\n\nconst slack_text = highRisk.length > 0 ? `${header}\\n${lines}${failedNote}` : `${header}${failedNote}`;\n\nconst audit = {\n  workflow: 'morning_risk_sweep',\n  run_id: $execution.id,\n  trigger: 'schedule',\n  scanned_at: now,\n  orders_scanned: scanned,\n  high_risk_count: highRisk.length,\n  scoring_failed_count: failed.length,\n  threshold: THRESHOLD,\n  high_risk_orders: highRisk.map((o) => ({\n    order_id: o.order_id,\n    order_number: o.order_number,\n    delay_probability: o.delay_probability,\n    root_cause: o.root_cause,\n    priority: o.priority,\n  })),\n};\n\nreturn [\n  {\n    json: {\n      slack_text,\n      audit,\n      orders_scanned: scanned,\n      high_risk_count: highRisk.length,\n      scoring_failed_count: failed.length,\n    },\n  },\n];\n"
      },
      "id": "2c1a0009-0000-0000-0000-000000000009",
      "name": "Build risk digest",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2000, 220]
    },
