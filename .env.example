# Manufacturing Process Copilot — environment template
# Copy this file to .env and fill in the values marked REQUIRED.
# .env is never committed to version control.

# ── LLM routing (REQUIRED) ────────────────────────────────────────────────────
# Get a free API key at https://openrouter.ai
OPENROUTER_API_KEY=

# Default models (free tier). Change to any OpenRouter-supported model.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen3-80b-a3b:free
OPENROUTER_CODER_MODEL=qwen/qwen3-coder:free

# LLM request timeout (seconds)
LLM_TIMEOUT_SECONDS=10.0

# ── Database ──────────────────────────────────────────────────────────────────
# Overridden by docker-compose.yml when running in Docker.
# Only set this when running the backend locally outside Docker.
# DATABASE_URL=postgresql+asyncpg://mpc:mpc@localhost:5432/mpc

# ── MLflow ────────────────────────────────────────────────────────────────────
# Overridden by docker-compose.yml when running in Docker.
# Only set when running locally.
# MLFLOW_TRACKING_URI=file:///absolute/path/to/mlruns
# MLFLOW_ALLOW_FILE_STORE=true

# ── Champion model run IDs ────────────────────────────────────────────────────
# These are pinned in backend/app/core/config.py.
# Override here only if you retrain and want to promote a new champion.
# BINARY_CHAMPION_RUN_ID=140ce9025def4436a397ef8333078202
# REGR_CHAMPION_RUN_ID=d10e7217af3b4b68920d895c244ca1aa
# RC_CHAMPION_RUN_ID=7cc43338ae434163a2207e052354db1b

# ── Business thresholds ───────────────────────────────────────────────────────
# Probability cutoff: orders above this are classified as at-risk
PREDICTION_THRESHOLD=0.65

# Orders above this threshold trigger a Slack alert via the order-released webhook
HIGH_RISK_THRESHOLD=0.70

# ── Notifications (optional) ─────────────────────────────────────────────────
# Leave empty to disable. Slack alerts fire when delay_probability >= HIGH_RISK_THRESHOLD.
SLACK_WEBHOOK_URL=

# Leave empty to disable email alerts.
ALERT_EMAIL_TO=

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
